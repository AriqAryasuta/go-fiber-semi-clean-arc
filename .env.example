# Copied to .env — loaded on startup by godotenv (config.Load) when the process cwd is the project root.
APP_NAME=backend-boiler
APP_ENV=development
APP_PORT=8080

DATABASE_URL=postgres://postgres:postgres@localhost:5432/backend_boiler?sslmode=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

RABBITMQ_URL=amqp://guest:guest@localhost:5672/

SHUTDOWN_TIMEOUT=10s
